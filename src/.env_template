# ─── BERTScore / SBERT ────────────────────────────────────────────────────────

# Device used to run BERTScore and SBERT models: 'cpu', 'cuda', 'gpu', or 'auto' (detects GPU automatically)
BERTSCORE_DEVICE=auto

# Initial number of parallel workers for the BERTScore service
BERTSCORE_WORKERS=5

# Maximum number of parallel workers allowed for the BERTScore service
BERTSCORE_MAX_WORKERS=5

# Timeout in seconds for BERTScore service requests
BERTSCORE_TIMEOUT=300

# ─── HuggingFace ──────────────────────────────────────────────────────────────

# Local directory where HuggingFace models are cached (avoids repeated downloads)
HF_HOME=./_models

# HuggingFace access token — required to download gated models (e.g. Gemma, Llama)
HF_TOKEN=<your token>

# Alias for HF_TOKEN used by some modules (keep consistent with HF_TOKEN)
HF=<your token>

# ─── LLM APIs ─────────────────────────────────────────────────────────────────

# API key for OpenRouter (https://openrouter.ai) — used by util_openai.py when model name starts with 'or:'
PESSOAL_OPENROUTER_API_KEY=<your token to openrouter.ai>
